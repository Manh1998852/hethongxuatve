<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hệ thống Vé Máy Bay v11.5 - Tối ưu Slogan & PDF</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <style>
        :root { --primary-color: #005aab; }
        body { font-family: 'Segoe UI', Arial, sans-serif; background-color: #e9ecef; padding: 10px; color: #333; }
        
        .admin-panel {
            max-width: 800px; margin: 0 auto 10px; background: white; border-radius: 8px;
            padding: 15px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 5px solid var(--primary-color);
        }
        .controls { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
        .btn-action { background: #f0f2f5; color: #333; padding: 6px 12px; border-radius: 4px; cursor: pointer; font-size: 12px; border: 1px solid #ddd; font-weight: 600; }
        
        #ticket-wrapper { background: #fff; width: 800px; margin: 0 auto; display: block; overflow: visible; }
        #ticket-content { background: #fff; border: 1px solid #ddd; width: 100%; display: block; overflow: visible; }
        
        .header { display: flex; justify-content: space-between; align-items: center; padding: 20px 25px; border-bottom: 3px solid var(--primary-color); }
        .logo-container img { height: 45px; width: auto; max-width: 200px; }

        .section-title { background: var(--primary-color); color: white; padding: 6px 20px; font-weight: bold; text-transform: uppercase; font-size: 12px; }
        [contenteditable="true"]:hover { background: #fffde7; outline: 1px dashed var(--primary-color); }

        .content-padding { padding: 8px 20px; }
        table { width: 100%; border-collapse: collapse; margin-bottom: 2px; }
        th { text-align: left; background: #f8f9fa; font-size: 10px; padding: 8px; border: 1px solid #eee; }
        td { padding: 8px; border: 1px solid #eee; vertical-align: middle; font-size: 13px; }

        .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; padding: 12px 20px; background: #fdfdfd; border-top: 1px solid #eee; }
        .info-item { font-size: 11px; line-height: 1.4; }
        .info-item strong { color: var(--primary-color); display: block; margin-bottom: 4px; text-transform: uppercase; border-bottom: 1px solid #eee; }

        #return-flight-section, .return-baggage-row { display: none; }
        
        .stamps-container { display: flex; justify-content: space-between; align-items: flex-end; padding: 15px 25px; border-top: 1px dashed #ddd; margin-top: 5px; min-height: 120px; }
        .qr-code img { width: 85px; height: 85px; padding: 4px; border: 1px solid #eee; background: white; }
        .paid-stamp { border: 2px solid #28a745; color: #28a745; padding: 6px 12px; font-weight: bold; border-radius: 4px; transform: rotate(-5deg); font-size: 14px; margin-bottom: 15px; }

        @media print { .admin-panel, .action-col { display: none !important; } }
    </style>
</head>
<body>

<div class="admin-panel">
    <div class="controls">
        <select class="btn-action" id="airline-theme" onchange="changeTheme()">
            <option value="vna">✈️ Vietnam Airlines</option>
            <option value="vj">✈️ Vietjet Air</option>
            <option value="sun">✈️ Sun PhuQuoc Airways</option>
        </select>
        <label class="btn-action" onclick="document.getElementById('logo-upload').click()">📁 ĐỔI LOGO</label>
        <input type="file" id="logo-upload" accept="image/*" style="display: none;" onchange="loadLogo(event)">
        <button class="btn-action" onclick="addPassenger()">👤 + KHÁCH</button>
        <div style="font-size:12px; font-weight:bold; color:var(--primary-color);">
            <input type="checkbox" id="roundtrip-toggle" onchange="toggleTripMode()"> KHỨ HỒI
        </div>
        <button class="btn-action" style="background:#28a745; color:white; margin-left:auto;" onclick="exportToPDF()">📥 TẢI VỀ PDF (FULL)</button>
    </div>
</div>

<div id="ticket-wrapper">
<div id="ticket-content">
    <div class="header">
        <div style="display: flex; align-items: center; gap: 12px;">
            <div class="logo-container"><img id="ticket-logo" src="https://upload.wikimedia.org/wikipedia/commons/thumb/a/ad/Vietnam_Airlines_logo_2015.svg/1280px-Vietnam_Airlines_logo_2015.svg.png"></div>
            <div style="display: flex; flex-direction: column; justify-content: center;">
                <div id="airline-display-name" style="font-weight: bold; font-size: 18px; line-height: 1;" contenteditable="true">VIETNAM AIRLINES</div>
                <div id="airline-slogan" style="font-size: 10px; opacity: 0.8; margin-top: 4px;" contenteditable="true">Thành viên của SkyTeam</div>
            </div>
        </div>
        <div style="text-align: right;">
            <div style="font-size: 10px; opacity: 0.7;">MÃ ĐẶT CHỖ / PNR</div>
            <div id="pnr-input" style="font-size: 24px; font-weight: bold; color: var(--primary-color); letter-spacing: 1px;" contenteditable="true">FXLXQW</div>
        </div>
    </div>

    <div class="section-title">Hành khách / Passenger</div>
    <div class="content-padding">
        <table id="passenger-table">
            <thead>
                <tr><th width="15%">DANH XƯNG</th><th width="45%">HỌ VÀ TÊN</th><th width="35%">TÌNH TRẠNG</th><th width="5%" class="action-col"></th></tr>
            </thead>
            <tbody>
                <tr>
                    <td contenteditable="true">MR</td>
                    <td class="passenger-name" style="font-weight: bold; text-transform: uppercase;" contenteditable="true">NGUYEN HOAI ANH</td>
                    <td contenteditable="true">CONFIRMED / OK</td>
                    <td class="action-col" onclick="removePassenger(this)" style="color:red; cursor:pointer; text-align:center;">×</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="section-title">Hành lý & Quy định / Baggage & Policy</div>
    <div class="info-grid">
        <div class="info-item">
            <strong>Hành lý (Baggage)</strong>
            <table style="border: none;">
                <tr><td style="border:none; padding:2px 0; font-size:11px;">✈️ Ký gửi:</td><td style="border:none; font-weight:bold; font-size:11px;" contenteditable="true">23kg (01 kiện)</td></tr>
                <tr class="return-baggage-row"><td style="border:none; padding:2px 0; font-size:11px;">✈️ Chiều về:</td><td style="border:none; font-weight:bold; font-size:11px;" contenteditable="true">23kg (01 kiện)</td></tr>
                <tr><td style="border:none; padding:2px 0; font-size:11px;">👜 Xách tay:</td><td style="border:none; font-weight:bold; color: #d93025; font-size:11px;" contenteditable="true">12kg (Tối đa)</td></tr>
            </table>
        </div>
        <div class="info-item">
            <strong>Lưu ý sân bay (Airport Notes)</strong>
            <div contenteditable="true" style="font-size: 10px;">
                • <b>Nội địa:</b> Có mặt trước <b>90 phút</b>.<br>
                • <b>Quốc tế:</b> Có mặt trước <b>180 phút</b>.<br>
                • Đóng quầy trước giờ bay 40-50 phút.
            </div>
        </div>
    </div>

    <div class="section-title">Chuyến đi / Departure Flight</div>
    <div class="content-padding">
        <table>
            <thead><tr><th>CHUYẾN BAY</th><th>NGÀY</th><th>KHỞI HÀNH</th><th>ĐẾN</th></tr></thead>
            <tbody>
                <tr>
                    <td contenteditable="true"><strong>VN 357</strong></td>
                    <td contenteditable="true">28/05/2026</td>
                    <td contenteditable="true"><strong>FUKUOKA (FUK)</strong><br><b>10:00</b></td>
                    <td contenteditable="true"><strong>HA NOI (HAN)</strong><br><b>12:30</b></td>
                </tr>
            </tbody>
        </table>
    </div>

    <div id="return-flight-section">
        <div class="section-title">Chuyến về / Return Flight</div>
        <div class="content-padding">
            <table>
                <thead><tr><th>CHUYẾN BAY</th><th>NGÀY</th><th>KHỞI HÀNH</th><th>ĐẾN</th></tr></thead>
                <tbody>
                    <tr>
                        <td contenteditable="true"><strong>VN 356</strong></td>
                        <td contenteditable="true">31/05/2026</td>
                        <td contenteditable="true"><strong>HA NOI (HAN)</strong><br><b>01:30</b></td>
                        <td contenteditable="true"><strong>FUKUOKA (FUK)</strong><br><b>07:35</b></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="stamps-container">
        <div class="qr-code"><img id="qr-image" src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=FXLXQW-NGUYEN-HOAI-ANH"></div>
        <div class="paid-stamp" contenteditable="true">ĐÃ THANH TOÁN</div>
        <div style="text-align: right; font-size: 11px;">
            <strong contenteditable="true" style="color: var(--primary-color);">SEN VIỆT TRAVEL GROUP</strong><br>
            <span contenteditable="true">Hotline: 0328.282828</span>
        </div>
    </div>
</div>
</div>

<script>
    function changeTheme() {
        const theme = document.getElementById('airline-theme').value;
        const logo = document.getElementById('ticket-logo');
        const name = document.getElementById('airline-display-name');
        const slogan = document.getElementById('airline-slogan');
        const root = document.documentElement;

        if (theme === 'sun') {
            logo.src = "https://i.ibb.co/Vvz8jYq/sun-pq-logo.png";
            name.innerText = "SUN PHU QUOC AIRWAYS";
            slogan.innerText = "Nâng tầm trải nghiệm nghỉ dưỡng";
            root.style.setProperty('--primary-color', '#002366');
        } else if (theme === 'vj') {
            logo.src = "https://upload.wikimedia.org/wikipedia/commons/thumb/d/d4/VietJet_Air_logo.svg/1280px-VietJet_Air_logo.svg.png";
            name.innerText = "VIETJET AIR";
            slogan.innerText = "Bay là thích ngay!";
            root.style.setProperty('--primary-color', '#e31937');
        } else {
            logo.src = "https://upload.wikimedia.org/wikipedia/commons/thumb/a/ad/Vietnam_Airlines_logo_2015.svg/1280px-Vietnam_Airlines_logo_2015.svg.png";
            name.innerText = "VIETNAM AIRLINES";
            slogan.innerText = "Thành viên của SkyTeam";
            root.style.setProperty('--primary-color', '#005aab');
        }
        updateQR();
    }

    function exportToPDF() {
        const element = document.getElementById('ticket-content');
        const pnr = document.getElementById('pnr-input').innerText.trim();
        const actionCols = document.querySelectorAll('.action-col');
        
        actionCols.forEach(col => col.style.display = 'none');

        const opt = {
            margin: 0.1,
            filename: `Ve_${pnr}.pdf`,
            image: { type: 'jpeg', quality: 1 },
            html2canvas: { scale: 2, useCORS: true, scrollY: 0, windowHeight: element.scrollHeight },
            jsPDF: { unit: 'in', format: 'a4', orientation: 'portrait', compress: true }
        };

        html2pdf().set(opt).from(element).save().then(() => {
            actionCols.forEach(col => col.style.display = '');
        });
    }

    function addPassenger() {
        const table = document.getElementById("passenger-table").getElementsByTagName('tbody')[0];
        const newRow = table.insertRow();
        newRow.innerHTML = `<td contenteditable="true">MS</td><td class="passenger-name" style="font-weight: bold; text-transform: uppercase;" contenteditable="true">TÊN KHÁCH</td><td contenteditable="true">CONFIRMED</td><td class="action-col" onclick="removePassenger(this)" style="color:red; cursor:pointer; text-align:center;">×</td>`;
        newRow.querySelector('.passenger-name').addEventListener('input', updateQR);
    }

    function removePassenger(btn) { if (document.querySelectorAll('#passenger-table tbody tr').length > 1) { btn.parentNode.remove(); updateQR(); } }
    
    function toggleTripMode() {
        const isRoundTrip = document.getElementById('roundtrip-toggle').checked;
        document.getElementById('return-flight-section').style.display = isRoundTrip ? 'block' : 'none';
        document.querySelectorAll('.return-baggage-row').forEach(row => row.style.display = isRoundTrip ? 'table-row' : 'none');
    }

    function loadLogo(event) {
        const reader = new FileReader();
        reader.onload = () => document.getElementById('ticket-logo').src = reader.result;
        reader.readAsDataURL(event.target.files[0]);
    }

    function updateQR() {
        const pnr = document.getElementById('pnr-input').innerText.trim().toUpperCase();
        const firstPass = document.querySelector('.passenger-name');
        const name = firstPass ? firstPass.innerText.trim().toUpperCase().replace(/\s+/g, '-') : "GUEST";
        document.getElementById('qr-image').src = `https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=${pnr}-${name}`;
    }

    document.getElementById('pnr-input').addEventListener('input', updateQR);
    document.querySelector('.passenger-name').addEventListener('input', updateQR);
</script>

</body>
</html>
